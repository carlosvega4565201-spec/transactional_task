# Copy to .env to override defaults. All values shown are the built-in defaults.

# Backend
DATABASE_URL=sqlite+aiosqlite:///./app.db
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=transactions:queue
EVENTS_CHANNEL=transactions:events

# Worker
WORKER_SLEEP_SECONDS=3
FAILURE_RATE=0.15

# RPA
API_URL=http://localhost:8000

# Frontend (build-time, read by Vite)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/transactions/stream
